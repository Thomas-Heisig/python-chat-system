APP_ENV=development
APP_NAME=kernschmiede
DATABASE_URL=sqlite+aiosqlite:///./data/database/chat_system.db
SECRET_KEY=change-this-key
SETTINGS_CACHE_TTL_SECONDS=5
MAX_ACTIVE_GENERATIONS=1
MAX_QUEUE_LENGTH=16
GPU_MEMORY_LIMIT_MB=11000
RAM_MEMORY_LIMIT_MB=24000

# Comma-separated list of allowed frontend origins for backend CORS.
# Example: http://localhost:5173,http://192.168.1.20:5173,https://chat.example.com
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional regex for dynamic origins (e.g. intranet subdomains):
# CORS_ALLOW_ORIGIN_REGEX=^https?://([a-z0-9-]+\.)*example\.com(:\d+)?$
CORS_ALLOW_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=true

# Frontend dev server network binding and API routing
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
VITE_DEV_BACKEND_TARGET=http://127.0.0.1:8000

# Optional explicit API base URL used by the frontend app (for intranet/internet reverse proxies)
# VITE_API_BASE_URL=https://chat.example.com
VITE_API_BASE_URL=

# Optional Vite host allow-list (comma-separated). Empty means allow all.
VITE_ALLOWED_HOSTS=

# Optional API keys. Never commit real secrets to versioned example files.
# ChatGPT / OpenAI API key (if you want to use an external API instead of Ollama)
CHATGPT_API_KEY=your-openai-api-key

# DeepL API key (if you want to use DeepL for translations)
DEEPL_API_KEY=your-deepl-api-key

# Additional optional LLM/API integration keys
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key
MISTRAL_API_KEY=your-mistral-api-key
COHERE_API_KEY=your-cohere-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
GROQ_API_KEY=your-groq-api-key
TOGETHER_API_KEY=your-together-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key
REPLICATE_API_KEY=your-replicate-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
XAI_API_KEY=your-xai-api-key
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AWS_BEDROCK_API_KEY=your-aws-bedrock-api-key
DEEPINFRA_API_KEY=your-deepinfra-api-key
NVIDIA_NIM_API_KEY=your-nvidia-nim-api-key
OCTOAI_API_KEY=your-octoai-api-key
FIREWORKS_API_KEY=your-fireworks-api-key
GITHUB_COPILOT_API_KEY=your-github-copilot-api-key

# Speech / audio providers
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# Vision / multimedia providers
STABILITY_API_KEY=your-stability-api-key
RUNWAY_API_KEY=your-runway-api-key
PIKA_API_KEY=your-pika-api-key
HEYGEN_API_KEY=your-heygen-api-key
FAL_API_KEY=your-fal-api-key

# Document / RAG providers
UNSTRUCTURED_API_KEY=your-unstructured-api-key
LLAMAPARSE_API_KEY=your-llamaparse-api-key
FIRECRAWL_API_KEY=your-firecrawl-api-key
PINECONE_API_KEY=your-pinecone-api-key
WEAVIATE_API_KEY=your-weaviate-api-key
QDRANT_API_KEY=your-qdrant-api-key
CLOUDCONVERT_API_KEY=your-cloudconvert-api-key

# Search / web / weather / maps providers
TAVILY_API_KEY=your-tavily-api-key
SERPAPI_API_KEY=your-serpapi-key
EXA_API_KEY=your-exa-api-key
BRAVE_SEARCH_API_KEY=your-brave-search-api-key
BING_SEARCH_API_KEY=your-bing-search-api-key
NEWSAPI_API_KEY=your-newsapi-key
GNEWS_API_KEY=your-gnews-api-key
SCRAPINGBEE_API_KEY=your-scrapingbee-api-key
APIFY_API_KEY=your-apify-api-key
OPENWEATHER_API_KEY=your-openweather-api-key
WEATHERAPI_API_KEY=your-weatherapi-key
TOMORROWIO_API_KEY=your-tomorrowio-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAPBOX_API_KEY=your-mapbox-api-key

# Data / finance providers
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key
YAHOO_FINANCE_API_KEY=your-yahoo-finance-api-key
OPENEXCHANGERATES_API_KEY=your-openexchangerates-api-key

# Communication / platform providers
TWILIO_API_KEY=your-twilio-api-key
SENDGRID_API_KEY=your-sendgrid-api-key
WHATSAPP_BUSINESS_API_KEY=your-whatsapp-business-api-key
SLACK_BOT_TOKEN=your-slack-bot-token
DISCORD_BOT_TOKEN=your-discord-bot-token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
MICROSOFT_TEAMS_API_KEY=your-microsoft-teams-api-key
CALENDLY_API_KEY=your-calendly-api-key
GITHUB_TOKEN=your-github-token
NOTION_API_KEY=your-notion-api-key
AIRTABLE_API_KEY=your-airtable-api-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# Security providers
VIRUSTOTAL_API_KEY=your-virustotal-api-key
HIBP_API_KEY=your-hibp-api-key

# Local runtime toggle (no key required)
OLLAMA_LOCAL_ENABLED=true