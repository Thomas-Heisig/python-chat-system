APP_ENV=development
APP_NAME=kernschmiede
DATABASE_URL=sqlite+aiosqlite:///./data/database/chat_system.db
SECRET_KEY=change-this-key
SETTINGS_CACHE_TTL_SECONDS=5
MAX_ACTIVE_GENERATIONS=1
MAX_QUEUE_LENGTH=16
GPU_MEMORY_LIMIT_MB=11000
RAM_MEMORY_LIMIT_MB=24000

# Comma-separated list of allowed frontend origins for backend CORS.
# Example: http://localhost:5173,http://192.168.1.20:5173,https://chat.example.com
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional regex for dynamic origins (e.g. intranet subdomains):
# CORS_ALLOW_ORIGIN_REGEX=^https?://([a-z0-9-]+\.)*example\.com(:\d+)?$
CORS_ALLOW_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=true

# Frontend dev server network binding and API routing
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
VITE_DEV_BACKEND_TARGET=http://127.0.0.1:8000

# Optional explicit API base URL used by the frontend app (for intranet/internet reverse proxies)
# VITE_API_BASE_URL=https://chat.example.com
VITE_API_BASE_URL=

# Optional Vite host allow-list (comma-separated). Empty means allow all.
VITE_ALLOWED_HOSTS=
